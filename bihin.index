<td>しるし半纏・法被</td><td>歴史を感じさせる藍染の風合い・額装展示</td><td><select><option></option><option>高</option><option>中</option><option>低</option></select></td><td><input type="text"></td><td></td><td><select><option>未着手</option><option>進行中</option><option>完了</option><option>保留</option></select></td></tr><tr><td>21</td><td>モニター動画配信</td><td>3ヶ国語ブランドストーリー</td><td><select><option></option><option>高</option><option>中</option><option>低</option></select></td><td><input type="text"></td><td></td><td><select><option>未着手</option><option>進行中</option><option>完了</option><option>保留</option></select></td></tr><tr class="category"><td colspan="7">その他</td></tr><tr><td>22</td><td>ユニフォーム一式</td><td>シャツ、エプロン、和装小物など</td><td><select><option></option><option>高</option><option>中</option><option>低</option></select></td><td><input type="text"></td><td></td><td><select><option>未着手</option><option>進行中</option><option>完了</option><option>保留</option></select></td></tr></tbody></table></div></body></html>
