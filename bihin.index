<!doctype html>
<html lang="ja"><head><meta charset="utf-8"><title>栞パッケージリスト</title>
<style>
body{font-family:Arial,"Noto Sans JP",sans-serif;background:#f7f8fa;margin:0;padding:24px;color:#222}
h1{font-size:22px}
.sheet{background:white;border:1px solid #ddd;border-radius:8px;overflow:auto;box-shadow:0 2px 8px #ddd}
table{border-collapse:collapse;min-width:1100px;width:100%}
th{background:#f1f3f4;position:sticky;top:0;z-index:2}
th,td{border:1px solid #ddd;padding:10px;white-space:nowrap}
.category{background:#eef5ff;font-weight:bold}
select,input{padding:4px;border:1px solid #bbb;border-radius:4px;background:white}
input{width:100px}
</style></head><body>
<h1>栞パッケージリスト</h1>
<div class="sheet"><table><thead><tr><th>#</th><th>品名</th><th>仕様・備考</th><th>優先度</th><th>概算コスト</th><th>担当</th><th>ステータス</th></tr></thead><tbody><tr class="category"><td colspan="7">デッキ</td></tr><tr><td>1</td><td>野点傘（赤）</td><td>デッキに1本、フォトスポット兼用</td><td><select><option></option><option>高</option><option>中</option><option>低</option></select></td><td><input type="text"></td><td></td><td><select><option>未着手</option><option>進行中</option><option>完了</option><option>保留</option></select></td></tr><tr><td>2</td><td>床几 × 2</td><td>折りたたみ式、茶屋スタイル</td><td><select><option></option><option>高</option><option>中</option><option>低</option></select></td><td><input type="text"></td><td></td><td><select><option>未着手</option><option>進行中</option><option>完了</option><option>保留</option></select></td></tr><tr><td>3</td><td>毛氈（赤）</td><td>床几に敷く赤フェルト</td><td><select><option></option><option>高</option><option>中</option><option>低</option></select></td><td><input type="text"></td><td></td><td><select><option>未着手</option><option>進行中</option><option>完了</option><option>保留</option></select></td></tr><tr><td>4</td><td>観葉植物</td><td>竹・盆栽など：購入・レンタル・イミテーション</td><td><select><option></option><option>高</option><option>中</option><option>低</option></select></td><td><input type="text"></td><td></td><td><select><option>未着手</option><option>進行中</option><option>完了</option><option>保留</option></select></td></tr><tr class="category"><td colspan="7">入口・外観</td></tr><tr><td>5</td><td>暖簾（のれん）</td><td>白×深緑、大きめサイズ、入口用</td><td><select><option></option><option>高</option><option>中</option><option>低</option></select></td><td><input type="text"></td><td></td><td><select><option>未着手</option><option>進行中</option><option>完了</option><option>保留</option></select></td></tr><tr><td>6</td><td>割れ暖簾</td><td></td><td><select><option></option><option>高</option><option>中</option><option>低</option></select></td><td><input type="text"></td><td></td><td><select><option>未着手</option><option>進行中</option><option>完了</option><option>保留</option></select></td></